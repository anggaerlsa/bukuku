APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Where author uploads go: `public` (storage/app/public) or `s3`.
# Leave it on public for local work; set s3 once the keys below are filled in,
# then carry the existing files over with `php artisan uploads:pindah`.
UPLOAD_DISK=public

# Serve pictures through short-lived signed URLs. Left unset it decides
# itself: signed on s3 (a private bucket answers 403 to plain URLs), plain on
# the local disk. Set false only if the bucket is publicly readable.
# UPLOAD_SIGNED=false
# UPLOAD_SIGNED_TTL=60

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# Public base URL for the bucket. Without it Laravel builds
# https://<bucket>.s3.<region>.amazonaws.com/<path>, which is right for a
# plain bucket; set it only when a CloudFront domain sits in front.
# AWS_URL=

VITE_APP_NAME="${APP_NAME}"

# Seeded accounts — override in .env; defaults are safe demo values.
SEED_SUPERADMIN_EMAIL=superadmin@bukuku.test
SEED_SUPERADMIN_PASSWORD=password
SEED_ADMIN_NAME=Admin
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@bukuku.test
SEED_ADMIN_PASSWORD=admin123
SEED_AUTHOR_EMAIL=author@bukuku.test
SEED_AUTHOR_PASSWORD=password
